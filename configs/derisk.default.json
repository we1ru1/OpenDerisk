{
  "name": "OpenDeRisk",
  "version": "0.1.0",
  "default_model": {
    "provider": "openai",
    "model_id": "gpt-4",
    "api_key": "${OPENAI_API_KEY}",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "agents": {
    "primary": {
      "name": "primary",
      "description": "主Agent - 执行核心任务",
      "max_steps": 20,
      "color": "#4A90E2",
      "permission": {
        "default_action": "allow",
        "rules": {
          "*": "allow",
          "*.env": "ask",
          "*.secret*": "ask",
          "bash:rm": "ask"
        }
      }
    },
    "readonly": {
      "name": "readonly",
      "description": "只读Agent - 仅允许读取操作",
      "max_steps": 10,
      "color": "#50C878",
      "permission": {
        "default_action": "deny",
        "rules": {
          "read": "allow",
          "glob": "allow",
          "grep": "allow"
        }
      }
    },
    "explore": {
      "name": "explore",
      "description": "探索Agent - 用于代码库探索",
      "max_steps": 15,
      "color": "#FFD700",
      "permission": {
        "default_action": "deny",
        "rules": {
          "read": "allow",
          "glob": "allow",
          "grep": "allow"
        }
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "image": "python:3.11-slim",
    "memory_limit": "512m",
    "timeout": 300,
    "network_enabled": false
  },
  "workspace": "~/.derisk/workspace",
  "log_level": "INFO",
  "server": {
    "host": "127.0.0.1",
    "port": 7777
  }
}